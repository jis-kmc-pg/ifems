import { useState, useCallback } from 'react';
import { useQuery } from '@tanstack/react-query';
import {
  AreaChart, Area, XAxis, YAxis, CartesianGrid,
  Tooltip, Legend, ResponsiveContainer, Brush, ReferenceArea,
} from 'recharts';
import PageHeader from '../../components/layout/PageHeader';
import ChartCard from '../../components/ui/ChartCard';
import TreeCheckbox from '../../components/ui/TreeCheckbox';
import FilterBar from '../../components/ui/FilterBar';
import { getFacilityTree, getFacilityHourlyData } from '../../services/analysis';
import { COLORS } from '../../lib/constants';

const TODAY = new Date().toISOString().slice(0, 10);

const TYPE_OPTIONS = [
  { value: 'elec', label: '전력(kWh)' },
  { value: 'air', label: '에어(L)' },
];

const CHART_COLORS = [
  COLORS.warning, COLORS.chart.blue, COLORS.chart.green,
  COLORS.chart.purple, COLORS.chart.red, COLORS.chart.cyan,
];

export default function ANL001Comparison() {
  const [checked, setChecked] = useState<Set<string>>(new Set(['HNK10-020', 'HNK10-010']));
  const [expanded, setExpanded] = useState<Set<string>>(new Set(['plant', 'block']));
  const [type, setType] = useState<'elec' | 'air'>('elec');
  const [date, setDate] = useState(TODAY);

  // 1. 범례 클릭 토글 상태
  const [hiddenSeries, setHiddenSeries] = useState<string[]>([]);

  // 2. 드래그 영역 선택 상태
  const [refAreaLeft, setRefAreaLeft] = useState<string | null>(null);
  const [refAreaRight, setRefAreaRight] = useState<string | null>(null);

  // 3. Brush 동기화 상태
  const [brushIndexes, setBrushIndexes] = useState<{ startIndex?: number; endIndex?: number }>({});

  // 범례 클릭 핸들러
  const handleLegendClick = useCallback((e: { dataKey: string }) => {
    setHiddenSeries((prev) =>
      prev.includes(e.dataKey) ? prev.filter((key) => key !== e.dataKey) : [...prev, e.dataKey]
    );
  }, []);

  // 드래그 시작
  const handleMouseDown = useCallback((e: { activeLabel?: string }) => {
    if (e.activeLabel) setRefAreaLeft(e.activeLabel);
  }, []);

  // 드래그 중
  const handleMouseMove = useCallback((e: { activeLabel?: string }) => {
    if (refAreaLeft && e.activeLabel) setRefAreaRight(e.activeLabel);
  }, [refAreaLeft]);

  // 리셋 핸들러
  const handleResetZoom = useCallback(() => {
    setBrushIndexes({});
  }, []);

  const { data: tree } = useQuery({ queryKey: ['anl-tree'], queryFn: getFacilityTree });

  // 선택된 설비들의 데이터를 병합
  const facilityIds = Array.from(checked).filter((id) => !['plant', 'block', 'head', 'crank', 'assembly'].includes(id));

  const queries = facilityIds.map((id) => {
    // eslint-disable-next-line react-hooks/rules-of-hooks
    return useQuery({
      queryKey: ['anl-hourly', id, type, date],
      queryFn: () => getFacilityHourlyData(id, type, date),
      enabled: facilityIds.length > 0,
    });
  });

  // 시간대 기준으로 데이터 병합
  const baseData = queries[0]?.data ?? [];
  const chartData = baseData.map((pt: { time: string; current: number }, i: number) => {
    const row: Record<string, string | number> = { time: pt.time };
    facilityIds.forEach((id, idx) => {
      row[id] = queries[idx]?.data?.[i]?.current ?? 0;
    });
    return row;
  });

  // 드래그 완료 → Brush 동기화 (chartData 이후에 정의)
  const handleMouseUp = useCallback(() => {
    if (refAreaLeft && refAreaRight && chartData.length > 0) {
      const leftIdx = chartData.findIndex((d) => d.time === refAreaLeft);
      const rightIdx = chartData.findIndex((d) => d.time === refAreaRight);
      if (leftIdx !== -1 && rightIdx !== -1) {
        const [start, end] = leftIdx < rightIdx ? [leftIdx, rightIdx] : [rightIdx, leftIdx];
        setBrushIndexes({ startIndex: start, endIndex: end });
      }
    }
    setRefAreaLeft(null);
    setRefAreaRight(null);
  }, [refAreaLeft, refAreaRight, chartData]);

  const unit = type === 'elec' ? 'kWh' : 'L';

  return (
    <div className="flex flex-col gap-4 h-full">
      <PageHeader title="비교 분석" description="설비 선택 후 당일 시간대별 에너지 비교 (최대 6개 설비)" />

      <FilterBar
        filters={[
          { type: 'select', key: 'type', label: '에너지 구분', value: type, onChange: (v) => setType(v as 'elec' | 'air'), options: TYPE_OPTIONS },
          { type: 'date', key: 'date', label: '날짜', value: date, onChange: setDate },
        ]}
        onSearch={() => {}}
        className="mb-0"
      />

      <div className="flex gap-3 flex-1 min-h-0">
        {/* 설비 트리 (좌) */}
        <div className="w-52 flex-shrink-0 bg-white dark:bg-[#769fb6] rounded-lg border border-gray-100 dark:border-gray-700 shadow-sm flex flex-col">
          <div className="px-3 py-2.5 border-b border-gray-100 dark:border-gray-700 flex-shrink-0">
            <div className="text-sm font-semibold text-gray-800 dark:text-white">설비 선택</div>
            <div className="text-xs text-gray-400 mt-0.5">{facilityIds.length}개 선택됨 (최대 6)</div>
          </div>
          <div className="flex-1 overflow-auto p-2">
            <TreeCheckbox
              nodes={tree ?? []}
              checked={checked}
              onCheckedChange={(next) => {
                const leafIds = Array.from(next).filter((id) => !['plant', 'block', 'head', 'crank', 'assembly'].includes(id));
                if (leafIds.length <= 6) setChecked(next);
              }}
              expanded={expanded}
              onExpandedChange={setExpanded}
            />
          </div>
        </div>

        {/* 차트 영역 (우) */}
        <div className="flex-1 flex flex-col gap-3 min-h-0">
          <ChartCard
            title={`설비별 시간대별 ${type === 'elec' ? '전력(kWh)' : '에어(L)'} 비교`}
            subtitle={`${date} — ${facilityIds.length}개 설비`}
            className="flex-1"
            chartId="anl001-chart"
            exportData={chartData}
            exportFilename="비교분석"
            minHeight={0}
          >
            {facilityIds.length === 0 ? (
              <div className="h-full flex items-center justify-center text-sm text-gray-400">
                좌측 트리에서 설비를 선택하세요 (1~6개)
              </div>
            ) : (
              <>
                {/* 리셋 버튼 */}
                {(brushIndexes.startIndex !== undefined || brushIndexes.endIndex !== undefined) && (
                  <button
                    onClick={handleResetZoom}
                    className="absolute top-2 right-2 z-10 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded-md shadow-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors text-xs font-medium text-gray-600 dark:text-gray-300 flex items-center gap-1.5"
                    title="차트 줌 리셋"
                  >
                    <svg className="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    리셋
                  </button>
                )}
                <ResponsiveContainer width="100%" height="100%">
                  <AreaChart
                    data={chartData}
                    margin={{ top: 4, right: 16, left: 8, bottom: 20 }}
                    onMouseDown={handleMouseDown}
                    onMouseMove={handleMouseMove}
                    onMouseUp={handleMouseUp}
                  >
                    <CartesianGrid strokeDasharray="3 3" stroke="#f0f0f0" />
                    <XAxis dataKey="time" tick={{ fontSize: 9 }} interval={7} />
                    <YAxis tick={{ fontSize: 10 }} tickFormatter={(v: number) => type === 'elec' ? String(v.toFixed(0)) : `${(v / 1000).toFixed(0)}K`} />
                    <Tooltip
                      contentStyle={{ background: 'rgba(26,26,46,0.95)', border: 'none', borderRadius: 8, fontSize: 12, color: '#fff' }}
                      formatter={(v: number, name: string) => [
                        type === 'elec' ? `${v.toFixed(2)} kWh` : `${(v / 1000).toFixed(1)} KL`,
                        name,
                      ]}
                      cursor={{ stroke: '#E94560', strokeWidth: 1, strokeDasharray: '5 5' }}
                    />
                    <Legend iconSize={10} wrapperStyle={{ fontSize: 11, cursor: 'pointer' }} onClick={handleLegendClick} />

                    {/* 드래그 선택 영역 */}
                    {refAreaLeft && refAreaRight && (
                      <ReferenceArea x1={refAreaLeft} x2={refAreaRight} fill={COLORS.accent} fillOpacity={0.2} />
                    )}

                    {facilityIds.map((id, idx) => (
                      <Area
                        key={id}
                        dataKey={id}
                        name={id}
                        stroke={CHART_COLORS[idx % 6]}
                        fill={CHART_COLORS[idx % 6] + '20'}
                        strokeWidth={2}
                        dot={false}
                        hide={hiddenSeries.includes(id)}
                      />
                    ))}

                    {/* Brush */}
                    <Brush
                      dataKey="time"
                      height={30}
                      stroke={COLORS.accent}
                      fill="rgba(233, 69, 96, 0.1)"
                      travellerWidth={8}
                      {...(brushIndexes.startIndex !== undefined && { startIndex: brushIndexes.startIndex })}
                      {...(brushIndexes.endIndex !== undefined && { endIndex: brushIndexes.endIndex })}
                      onChange={(range) => setBrushIndexes({ startIndex: range.startIndex, endIndex: range.endIndex })}
                    />
                  </AreaChart>
                </ResponsiveContainer>
              </>
            )}
          </ChartCard>

          {/* 선택 설비 요약 카드 */}
          {facilityIds.length > 0 && (
            <div className="flex gap-2 flex-shrink-0 flex-wrap">
              {facilityIds.map((id, idx) => {
                const vals = queries[idx]?.data?.map((d: { current: number }) => d.current) ?? [];
                const total = vals.reduce((s: number, v: number) => s + v, 0);
                return (
                  <div key={id} className="bg-white dark:bg-[#769fb6] rounded-lg border border-gray-100 dark:border-gray-700 px-3 py-2 flex items-center gap-2 shadow-sm">
                    <span className="w-2.5 h-2.5 rounded-full flex-shrink-0" style={{ background: CHART_COLORS[idx % 6] }} />
                    <div>
                      <div className="text-xs font-bold text-gray-800 dark:text-white">{id}</div>
                      <div className="text-xs text-gray-400">
                        합계: {type === 'elec' ? `${total.toFixed(1)} kWh` : `${(total / 1000).toFixed(0)} KL`}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
