# Database Configuration
# PostgreSQL connection string with TimescaleDB extension
DATABASE_URL="postgresql://username:password@localhost:5432/ifems?schema=public"

# Server Configuration
PORT=4000
NODE_ENV=development

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3200,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:1420

# JWT Configuration
# IMPORTANT: Change this secret in production!
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=1d

# TimescaleDB Configuration
TIMESCALE_ENABLED=true
TIMESCALE_CHUNK_INTERVAL=7days

# Logging Configuration
# Options: error, warn, info, debug, verbose
LOG_LEVEL=debug
